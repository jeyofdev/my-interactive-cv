// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "mongodb"
  url = env("DATABASE_URL")
}

model Resume {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  title     String
  summary   String
  email     String
  phone     String
  location  String
  birthDate String
  vehicle   Vehicle
  website   Website
  social    Social
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  skills      Skill[]
  languages   Language[]
  hobbies     Hobby[]
  experiences Experience[]
  projects    Project[]
  education   Education[]
}

model Skill {
  id       String      @id @default(auto()) @map("_id") @db.ObjectId
  category String
  items    SkillItem[]
  resume   Resume      @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId String      @db.ObjectId
}

type SkillItem {
  id    String @db.ObjectId  // ObjectId pour les types imbriqués
  label String
}

model Language {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  label    String
  level    String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId String @db.ObjectId
}

model Hobby {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  label    String
  detail   String?
  duration String?
  resume   Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId String  @db.ObjectId
}

model Experience {
  id           String                 @id @default(auto()) @map("_id") @db.ObjectId
  company      String
  role         String
  period       String
  type         String
  description  String
  details      ExperienceDetail[]
  formations   ExperienceFormation[]
  technologies ExperienceTechnology[]
  resume       Resume                 @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId     String                 @db.ObjectId
}

type ExperienceDetail {
  id   String @db.ObjectId  // ObjectId
  body String
}

type ExperienceFormation {
  id    String @db.ObjectId  // ObjectId
  label String
}

type ExperienceTechnology {
  id    String @db.ObjectId  // ObjectId
  label String
}

model Project {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  image       String
  tags        ProjectTag[]
  links       ProjectLink[]
  resume      Resume        @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId    String        @db.ObjectId
}

type ProjectTag {
  id    String @db.ObjectId
  label String
}

type ProjectLink {
  id    String @db.ObjectId
  label String
  url   String
}

model Education {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  school         String
  degree         String
  year           String
  specialization String
  resume         Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId       String @db.ObjectId
}

type Vehicle {
  carLicense Boolean
  vehicule   Boolean
}

type Website {
  label String
  url   String
}

type Social {
  linkedin SocialLink
  github   SocialLink
}

type SocialLink {
  label String
  url   String
}