{
	"name": "my-interactive-cv",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "echo '🔍 Biomejs Execution...' && bunx biome lint --write ./app",
		"format": "echo '✨ Code formatting with Biomejs...' && bunx biome format --write ./app",
		"check": "bunx biome check --write ./app",
		"prepare": "echo '🚀 Preparing the Husky hooks...' && husky",
		"seed": "node --env-file=.env node_modules/.bin/tsx prisma/seed.ts"
	},
	"dependencies": {
		"@prisma/client": "6.19",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.3.1",
		"framer-motion": "^12.34.1",
		"lucide-react": "^0.574.0",
		"next": "16.1.6",
		"next-themes": "^0.4.6",
		"pg": "^8.18.0",
		"radix-ui": "^1.4.3",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"tailwind-merge": "^3.4.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.0",
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^25.3.0",
		"@types/pg": "^8.16.0",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"prisma": "6.19",
		"shadcn": "^3.8.5",
		"tailwindcss": "^4",
		"ts-node": "^10.9.2",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5"
	},
	"ignoreScripts": [
		"sharp",
		"unrs-resolver"
	],
	"trustedDependencies": [
		"sharp",
		"unrs-resolver"
	],
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"echo '🔧 Linting des fichiers modifiés...'",
			"bunx biome lint --write ./src",
			"echo '✨ Formatage des fichiers modifiés...'",
			"bunx biome format --write ./src"
		]
	},
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	}
}